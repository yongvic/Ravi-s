# ============================================
# RAVI'S - ENVIRONMENT CONFIGURATION
# ============================================

# DATABASE
# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/database"

# NEXTAUTH.JS
# Generate secret: openssl rand -hex 32
NEXTAUTH_SECRET="your-generated-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# VERCEL BLOB STORAGE
# Get token from: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN="your-blob-token-here"

# EMAIL (OPTIONAL - for password reset emails)
# If not configured, reset link is logged on server console in development
RESEND_API_KEY=""
EMAIL_FROM="Ravi's <no-reply@yourdomain.com>"

# NODE ENVIRONMENT
NODE_ENV="development"

# ============================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your-analytics-id"
# SENTRY_AUTH_TOKEN="your-sentry-token"
